#!/usr/bin/env sh
set -eu

# Resolve repository root independently of caller directory.
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$REPO_ROOT"

echo "[post-checkout] Running validation suite..."

# Validate instruction/routing/skills contracts after checkout/switch.
if command -v pwsh >/dev/null 2>&1; then
  if ! pwsh -NoLogo -NoProfile -File ./scripts/validation/validate-all.ps1 -ValidationProfile dev -WarningOnly true; then
    echo "[post-checkout] Warning: validation command failed." >&2
  fi
  exit 0
fi

# Windows PowerShell fallback.
if command -v powershell >/dev/null 2>&1; then
  if ! powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\validation\\validate-all.ps1 -ValidationProfile dev -WarningOnly true; then
    echo "[post-checkout] Warning: validation command failed." >&2
  fi
  exit 0
fi

echo "[post-checkout] Warning: PowerShell not found. Validation skipped." >&2
exit 0