#!/usr/bin/env sh
set -eu

# Resolve repository root independently of caller directory.
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$REPO_ROOT"

echo "[post-merge] Running instruction validation..."
log_retention_days="${CODEX_LOG_RETENTION_DAYS:-7}"

# Validate instruction/routing/skills contracts after merge updates.
if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/validation/validate-instructions.ps1
  pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/validation/validate-policy.ps1
  pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/validation/validate-agent-orchestration.ps1
  pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/validation/validate-release-governance.ps1

  if [ "${CODEX_SKIP_RUNTIME_CLEANUP:-0}" = "1" ]; then
    echo "[post-merge] Runtime cleanup skipped (CODEX_SKIP_RUNTIME_CLEANUP=1)."
  else
    echo "[post-merge] Running runtime cleanup (log retention: ${log_retention_days} days)..."
    if ! pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/runtime/clean-codex-runtime.ps1 -LogRetentionDays "$log_retention_days" -Apply; then
      echo "[post-merge] Warning: runtime cleanup failed." >&2
    fi
  fi

  exit 0
fi

# Windows PowerShell fallback.
if command -v powershell >/dev/null 2>&1; then
  powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\validation\\validate-instructions.ps1
  powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\validation\\validate-policy.ps1
  powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\validation\\validate-agent-orchestration.ps1
  powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\validation\\validate-release-governance.ps1

  if [ "${CODEX_SKIP_RUNTIME_CLEANUP:-0}" = "1" ]; then
    echo "[post-merge] Runtime cleanup skipped (CODEX_SKIP_RUNTIME_CLEANUP=1)."
  else
    echo "[post-merge] Running runtime cleanup (log retention: ${log_retention_days} days)..."
    if ! powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\runtime\\clean-codex-runtime.ps1 -LogRetentionDays "$log_retention_days" -Apply; then
      echo "[post-merge] Warning: runtime cleanup failed." >&2
    fi
  fi

  exit 0
fi

echo "[post-merge] PowerShell not found. Install pwsh to run instruction/policy/release validation." >&2
exit 1