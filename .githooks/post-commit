#!/usr/bin/env sh
set -u

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$REPO_ROOT"

if [ "${CODEX_SKIP_POST_COMMIT_SYNC:-0}" = "1" ]; then
  echo "[post-commit] Sync skipped (CODEX_SKIP_POST_COMMIT_SYNC=1)."
  exit 0
fi

run_sync() {
  cmd="$1"
  echo "[post-commit] Syncing ~/.github and ~/.codex from repository..."
  if ! "$cmd" -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/runtime/bootstrap.ps1; then
    echo "[post-commit] Warning: sync failed." >&2
    return 0
  fi
  echo "[post-commit] Sync complete."
  return 0
}

if command -v pwsh >/dev/null 2>&1; then
  run_sync pwsh
  exit 0
fi

if command -v powershell >/dev/null 2>&1; then
  run_sync powershell
  exit 0
fi

echo "[post-commit] Warning: PowerShell not found. Sync skipped." >&2
exit 0
