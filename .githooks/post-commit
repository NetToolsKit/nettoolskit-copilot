#!/usr/bin/env sh
set -u

# Resolve repository root and local home folder once.
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$REPO_ROOT"
CODEX_HOME="${HOME:-${USERPROFILE:-}}"

# Emergency bypass for troubleshooting sessions.
if [ "${CODEX_SKIP_POST_COMMIT_SYNC:-0}" = "1" ]; then
  echo "[post-commit] Sync skipped (CODEX_SKIP_POST_COMMIT_SYNC=1)."
  exit 0
fi

# Resolve PowerShell runtime (pwsh first, then Windows PowerShell).
resolve_ps_cmd() {
  if command -v pwsh >/dev/null 2>&1; then
    echo "pwsh"
    return 0
  fi

  if command -v powershell >/dev/null 2>&1; then
    echo "powershell"
    return 0
  fi

  echo ""
  return 0
}

# Runs a PowerShell script with cross-platform flags.
run_ps_file() {
  cmd="$1"
  script_path="$2"
  shift 2

  if [ "$cmd" = "powershell" ]; then
    "$cmd" -NoLogo -NoProfile -ExecutionPolicy Bypass -File "$script_path" "$@"
    return $?
  fi

  "$cmd" -NoLogo -NoProfile -File "$script_path" "$@"
  return $?
}

# Keep local runtime folders aligned with repo source-of-truth.
run_sync() {
  cmd="$1"
  echo "[post-commit] Syncing ~/.github and ~/.codex from repository..."
  mirror_mode="${CODEX_POST_COMMIT_MIRROR:-1}"
  if [ "$mirror_mode" = "0" ]; then
    sync_args=""
  else
    sync_args="-Mirror"
  fi

  if ! run_ps_file "$cmd" ./scripts/runtime/bootstrap.ps1 $sync_args; then
    echo "[post-commit] Warning: sync failed." >&2
    return 0
  fi
  echo "[post-commit] Sync complete."
  return 0
}

# Clean local Codex runtime garbage and keep only recent logs.
# Controlled by:
# - CODEX_SKIP_RUNTIME_CLEANUP=1
# - CODEX_LOG_RETENTION_DAYS=<days> (default 30)
# - CODEX_INCLUDE_SESSIONS_CLEANUP=0|1 (default 1)
# - CODEX_SESSION_RETENTION_DAYS=<days> (default 30)
run_runtime_cleanup() {
  cmd="$1"

  if [ "${CODEX_SKIP_RUNTIME_CLEANUP:-0}" = "1" ]; then
    echo "[post-commit] Runtime cleanup skipped (CODEX_SKIP_RUNTIME_CLEANUP=1)."
    return 0
  fi

  log_retention_days="${CODEX_LOG_RETENTION_DAYS:-30}"
  include_sessions_cleanup="${CODEX_INCLUDE_SESSIONS_CLEANUP:-1}"
  session_retention_days="${CODEX_SESSION_RETENTION_DAYS:-30}"
  echo "[post-commit] Running runtime cleanup (log retention: ${log_retention_days} days)..."

  cleanup_args="-LogRetentionDays $log_retention_days -Apply"
  if [ "$include_sessions_cleanup" = "1" ]; then
    cleanup_args="$cleanup_args -IncludeSessions -SessionRetentionDays $session_retention_days"
  fi

  if ! run_ps_file "$cmd" ./scripts/runtime/clean-codex-runtime.ps1 $cleanup_args; then
    echo "[post-commit] Warning: runtime cleanup failed." >&2
    return 0
  fi

  echo "[post-commit] Runtime cleanup complete."
  return 0
}

# Optionally apply MCP config when manifest changed in last commit.
# Controlled by:
# - CODEX_APPLY_MCP_ON_POST_COMMIT=1
# - CODEX_BACKUP_MCP_CONFIG=1|0 (default 1)
run_optional_mcp_apply() {
  cmd="$1"
  changed_files="$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null || true)"
  manifest_changed=0

  if printf '%s\n' "$changed_files" | grep -Eq '^\.codex/mcp/servers\.manifest\.json$'; then
    manifest_changed=1
  fi

  if [ "$manifest_changed" -ne 1 ]; then
    return 0
  fi

  if [ "${CODEX_APPLY_MCP_ON_POST_COMMIT:-0}" != "1" ]; then
    echo "[post-commit] MCP manifest changed; apply is disabled (set CODEX_APPLY_MCP_ON_POST_COMMIT=1)."
    return 0
  fi

  if [ -z "$CODEX_HOME" ]; then
    echo "[post-commit] Warning: HOME/USERPROFILE not found; MCP apply skipped." >&2
    return 0
  fi

  target_config="$CODEX_HOME/.codex/config.toml"
  echo "[post-commit] MCP manifest changed. Applying mcp_servers to $target_config ..."

  if [ "${CODEX_BACKUP_MCP_CONFIG:-1}" = "1" ]; then
    if ! run_ps_file "$cmd" ./.codex/scripts/sync-mcp-to-codex-config.ps1 -ManifestPath ./.codex/mcp/servers.manifest.json -TargetConfigPath "$target_config" -CreateBackup; then
      echo "[post-commit] Warning: MCP apply failed." >&2
      return 0
    fi
  else
    if ! run_ps_file "$cmd" ./.codex/scripts/sync-mcp-to-codex-config.ps1 -ManifestPath ./.codex/mcp/servers.manifest.json -TargetConfigPath "$target_config"; then
      echo "[post-commit] Warning: MCP apply failed." >&2
      return 0
    fi
  fi

  echo "[post-commit] MCP apply complete."
  return 0
}

# Validates repository .vscode templates against global VS Code user files.
# Controlled by:
# - CODEX_SKIP_VSCODE_GLOBAL_CHECK=1
# - CODEX_VSCODE_GLOBAL_USER_PATH=<absolute path>
# - CODEX_SKIP_VSCODE_SNIPPET_CHECK=1
run_vscode_global_check() {
  cmd="$1"

  if [ "${CODEX_SKIP_VSCODE_GLOBAL_CHECK:-0}" = "1" ]; then
    echo "[post-commit] VS Code global check skipped (CODEX_SKIP_VSCODE_GLOBAL_CHECK=1)."
    return 0
  fi

  echo "[post-commit] Validating .vscode templates against global VS Code User settings..."

  if [ -n "${CODEX_VSCODE_GLOBAL_USER_PATH:-}" ]; then
    if [ "${CODEX_SKIP_VSCODE_SNIPPET_CHECK:-0}" = "1" ]; then
      if ! run_ps_file "$cmd" ./scripts/runtime/validate-vscode-global-alignment.ps1 -GlobalVscodeUserPath "$CODEX_VSCODE_GLOBAL_USER_PATH" -SkipSnippets; then
        echo "[post-commit] Warning: VS Code global check failed." >&2
        return 0
      fi
    else
      if ! run_ps_file "$cmd" ./scripts/runtime/validate-vscode-global-alignment.ps1 -GlobalVscodeUserPath "$CODEX_VSCODE_GLOBAL_USER_PATH"; then
        echo "[post-commit] Warning: VS Code global check failed." >&2
        return 0
      fi
    fi
  else
    if [ "${CODEX_SKIP_VSCODE_SNIPPET_CHECK:-0}" = "1" ]; then
      if ! run_ps_file "$cmd" ./scripts/runtime/validate-vscode-global-alignment.ps1 -SkipSnippets; then
        echo "[post-commit] Warning: VS Code global check failed." >&2
        return 0
      fi
    else
      if ! run_ps_file "$cmd" ./scripts/runtime/validate-vscode-global-alignment.ps1; then
        echo "[post-commit] Warning: VS Code global check failed." >&2
        return 0
      fi
    fi
  fi

  echo "[post-commit] VS Code global check complete."
  return 0
}

# Hook is best-effort: no hard failure if PowerShell is unavailable.
PS_CMD="$(resolve_ps_cmd)"
if [ -z "$PS_CMD" ]; then
  echo "[post-commit] Warning: PowerShell not found. Sync skipped." >&2
  exit 0
fi

run_sync "$PS_CMD"
run_optional_mcp_apply "$PS_CMD"
run_vscode_global_check "$PS_CMD"
run_runtime_cleanup "$PS_CMD"
exit 0