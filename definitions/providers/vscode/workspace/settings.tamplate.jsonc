    // Terminal Auto-Approve - Safe commands for multi-language development
    "chat.tools.terminal.autoApprove": {
        // .NET Commands
        "dotnet build": true,
        "dotnet restore": true,
        "dotnet test": true,
        "dotnet run": true,
        "dotnet clean": true,

        // Node.js / npm / pnpm / yarn
        "npm install": true,
        "npm i": true,
        "npm init": true,
        "npm run dev": true,
        "npm run build": true,
        "npm run test": true,
        "npm run test:run": true,
        "npm run test:coverage": true,
        "npm run lint": true,
        "npm run format": true,
        "pnpm install": true,
        "pnpm dev": true,
        "pnpm build": true,
        "pnpm test": true,
        "yarn install": true,
        "yarn dev": true,
        "yarn build": true,
        "yarn test": true,
        "npx": true,

        // Vue / Quasar / Vite
        "vite": true,
        "vite build": true,
        "vite preview": true,
        "quasar dev": true,
        "quasar build": true,
        "quasar clean": true,
        "quasar inspect": true,
        "vue-cli-service serve": true,
        "vue-cli-service build": true,

        // Rust Commands
        "cargo build": true,
        "cargo run": true,
        "cargo test": true,
        "cargo check": true,
        "cargo clean": true,
        "cargo clippy": true,
        "cargo fmt": true,

        // Clojure Commands
        "clojure": true,
        "clj": true,
        "lein test": true,
        "lein run": true,

        // PowerShell Cmdlets
        "Copy-Item": true,
        "Move-Item": true,
        "mv": true,
        "New-Item": true,
        "Out-File": true,
        "Out-Null": true,
        "Test-Path": true,
        "Push-Location": true,
        "Pop-Location": true,
        "ForEach-Object": true,
        "Set-Content": true,
        "Get-Content": true,
        "Remove-Item": false,
        "rm": false,
        "taskkill": true,
        "$null": true,
        "$content": true,
        "Expression={[math]::Round($_.Length/1MB,2)}}": true
    },

