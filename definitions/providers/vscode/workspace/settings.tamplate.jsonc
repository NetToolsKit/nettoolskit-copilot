// ═══════════════════════════════════════════════════════════════════════════════════════════════
// VS CODE WORKSPACE SETTINGS
// ═══════════════════════════════════════════════════════════════════════════════════════════════
//
// This file consolidates ALL VS Code workspace settings including:
//   - Editor, terminal, workbench, and UI configurations
//   - Git/SCM, GitHub, and remote development settings
//   - Language-specific formatters and behaviors
//   - Extensions and development tools
//   - GitHub Copilot and AI Chat configurations
//   - File references for Copilot instructions and custom modes
//
// Structure:
//   Lines 1-320:   Core VS Code settings (editor, terminal, languages, etc.)
//   Lines 321-490: GitHub Copilot & AI Chat (enable, chat modes, MCP, file references)
//   Lines 491-end: Terminal auto-approve, telemetry, and extension-specific settings
//
// Copilot File References:
//   Update paths to point to your %USERPROFILE% shared instruction runtime:
//   %USERPROFILE%\.github\
//   ├── AGENTS.md
//   ├── copilot-instructions.md
//   ├── chatmodes\*.chatmode.md
//   └── instructions\<domain>\ntk-*.instructions.md
//   %USERPROFILE%\.codex\skills\
//   └── <skill-name>\SKILL.md
//
// ═══════════════════════════════════════════════════════════════════════════════════════════════
{
    // EDITOR - Basic editor settings
    // https://code.visualstudio.com/docs/getstarted/settings#_editor
    "editor.fontFamily": "'Cascadia Code PL', Consolas, 'Courier New', monospace",
    "editor.fontSize": 13,
    "editor.formatOnSave": false,
    "editor.formatOnPaste": false,
    "editor.formatOnType": false,
    "editor.stickyScroll.enabled": false,
    "editor.renderWhitespace": "none",
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": true,
    "editor.minimap.enabled": true,
    "editor.minimap.maxColumn": 120,
    "editor.rulers": [
        {
            "column": 100,
            "color": "#09ff0033",
            "lineStyle": "dashed"
        },
        {
            "column": 170,
            "color": "#ff00004d",
            "lineStyle": "dashed"
        },
        {
            "column": 175,
            "color": "#ffee0050",
            "lineStyle": "dashed"
        }
    ],
    "editor.wordWrap": "wordWrapColumn",
    "editor.wordWrapColumn": 160,
    "editor.trimAutoWhitespace": true,
    "editor.insertSpaces": true,
    "editor.detectIndentation": true,
    "editor.suggestSelection": "first",
    "editor.acceptSuggestionOnCommitCharacter": false,
    "editor.acceptSuggestionOnEnter": "on",
    "editor.tabCompletion": "on",
    "editor.parameterHints.enabled": true,
    "editor.tokenColorCustomizations": {
        "[*Light*]": {
            "textMateRules": [
                {
                    "scope": "ref.matchtext",
                    "settings": {
                        "foreground": "#000"
                    }
                }
            ]
        },
        "[*Dark*]": {
            "textMateRules": [
                {
                    "scope": "ref.matchtext",
                    "settings": {
                        "foreground": "#fff"
                    }
                }
            ]
        },
        "textMateRules": [
            { "scope": "meta.timestamp.tomcat", "settings": { "foreground": "#858585", "fontStyle": "" } },
            { "scope": "support.type.log-level.info.tomcat", "settings": { "foreground": "#4FC1FF", "fontStyle": "" } },
            { "scope": "support.type.log-level.debug.tomcat", "settings": { "foreground": "#888888", "fontStyle": "bold" } },
            { "scope": "support.type.log-level.error.tomcat", "settings": { "foreground": "#D32F2F", "fontStyle": "bold" } },
            { "scope": "support.type.log-level.success.tomcat", "settings": { "foreground": "#73C991", "fontStyle": "" } },
            { "scope": "support.type.log-level.warn.tomcat", "settings": { "foreground": "#FF6B6B", "fontStyle": "" } },
            { "scope": "entity.name.log-level.brackets.tomcat", "settings": { "foreground": "#FFD700", "fontStyle": "" } },
            { "scope": "markup.underline.link.tomcat", "settings": { "foreground": "#61AFEF", "fontStyle": "underline" } },
            { "scope": "entity.name.filename.java.tomcat", "settings": { "foreground": "#9CDCFE", "fontStyle": "underline" } },
            { "scope": "constant.numeric.build-duration.tomcat", "settings": { "foreground": "#B5CEA8" } },
            { "scope": "constant.numeric.integer.tomcat", "settings": { "foreground": "#B5CEA8" } },
            { "scope": "entity.name.class.java.tomcat", "settings": { "foreground": "#4EC9B0", "fontStyle": "" } },
            { "scope": "entity.name.function.java.tomcat", "settings": { "foreground": "#DCDCAA", "fontStyle": "" } },
            { "scope": "variable.parameter.java.tomcat", "settings": { "foreground": "#9CDCFE", "fontStyle": "" } },
            { "scope": "variable.other.object.java.tomcat", "settings": { "foreground": "#DCDCAA", "fontStyle": "" } },
            { "scope": "storage.modifier.java.tomcat", "settings": { "foreground": "#569CD6", "fontStyle": "" } },
            { "scope": "storage.type.java.tomcat", "settings": { "foreground": "#4EC9B0", "fontStyle": "" } },
            { "scope": "keyword.control.java.tomcat", "settings": { "foreground": "#C586C0", "fontStyle": "" } },
            { "scope": "invalid.illegal.java.tomcat", "settings": { "foreground": "#FF6B6B", "fontStyle": "bold" } },
            { "scope": "markup.error.tomcat", "settings": { "foreground": "#FF6B6B", "fontStyle": "bold" } },
            { "scope": "string.quoted.double.java.tomcat", "settings": { "foreground": "#CE9178", "fontStyle": "" } },
            { "scope": "keyword.operator.java.tomcat", "settings": { "foreground": "#D4D4D4", "fontStyle": "" } },
            { "scope": "storage.type.annotation.java.tomcat", "settings": { "foreground": "#569CD6", "fontStyle": "" } },
            { "scope": "meta.annotation.parameters.java.tomcat", "settings": { "foreground": "#9CDCFE", "fontStyle": "" } },
            { "scope": "punctuation.terminator.java.tomcat", "settings": { "foreground": "#D4D4D4" } },
            { "scope": "punctuation.separator.comma.java.tomcat", "settings": { "foreground": "#D4D4D4" } },
            { "scope": "punctuation.bracket.square.java.tomcat", "settings": { "foreground": "#D4D4D4" } },
            { "scope": "punctuation.bracket.round.java.tomcat", "settings": { "foreground": "#D4D4D4" } },
            { "scope": "punctuation.bracket.angle.java.tomcat", "settings": { "foreground": "#D4D4D4" } },
            { "scope": "entity.name.package.java.tomcat", "settings": { "foreground": "#858585", "fontStyle": "" } },
            { "scope": "keyword.control.import.java.tomcat", "settings": { "foreground": "#569CD6", "fontStyle": "" } },
            { "scope": "support.type.log-level.http.tomcat", "settings": { "foreground": "#4EC9B0", "fontStyle": "bold" } },
            { "scope": "http.method.tomcat", "settings": { "foreground": "#C586C0", "fontStyle": "bold" } },
            { "scope": "http.status.success.tomcat", "settings": { "foreground": "#73C991", "fontStyle": "bold" } },
            { "scope": "http.status.redirect.tomcat", "settings": { "foreground": "#4FC1FF", "fontStyle": "bold" } },
            { "scope": "http.status.client-error.tomcat", "settings": { "foreground": "#FFCC66", "fontStyle": "bold" } },
            { "scope": "http.response.size.tomcat", "settings": { "foreground": "#B5CEA8", "fontStyle": "" } },
            { "scope": "entity.name.user.admin.tomcat", "settings": { "foreground": "#FFA07A", "fontStyle": "italic" } }
        ]
    },
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit"
    },

    // DIFF EDITOR - File diff editor
    // https://code.visualstudio.com/docs/editor/versioncontrol#_viewing-diffs
    "diffEditor.codeLens": true,
    "diffEditor.ignoreTrimWhitespace": false,
    "diffEditor.maxComputationTime": 0,

    // INTEGRATED TERMINAL - Internal terminal settings
    // https://code.visualstudio.com/docs/terminal/basics
    "terminal.integrated.shellIntegration.enabled": true,
    "terminal.integrated.shellIntegration.decorationsEnabled": "both",
    "terminal.integrated.shellIntegration.showCommandGuide": true,
    "terminal.integrated.gpuAcceleration": "auto",
    "terminal.integrated.cursorStyle": "block",
    "terminal.integrated.fontSize": 12,
    "terminal.integrated.fontFamily": "MesloLGM Nerd Font",
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.profiles.windows": {},
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.integrated.defaultProfile.linux": "zsh",
    "terminal.integrated.profiles.linux": {
        "zsh": {
            "path": "/usr/bin/zsh",
            "args": ["-l"]
        }
    },
    "terminal.integrated.ignoreProcessNames": ["oh-my-posh", "bash", "zsh"],

    // WORKBENCH - General VS Code interface
    // https://code.visualstudio.com/docs/getstarted/userinterface
    "window.restoreWindows": "all",
    "workbench.startupEditor": "welcomePage",
    "workbench.editor.pinnedTabsOnSeparateRow": true,
    "workbench.iconTheme": "material-icon-theme",
    "workbench.secondarySideBar.defaultVisibility": "visible",
    "workbench.activityBar.location": "default",
    "workbench.settings.enableNaturalLanguageSearch": true,
    "workbench.tree.renderIndentGuides": "always",
    "workbench.tree.indent": 20,

    // EXPLORER & FILES - File management and explorer
    // https://code.visualstudio.com/docs/getstarted/userinterface#_explorer
    "explorer.compactFolders": false,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.sortOrder": "type",
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "files.encoding": "utf8",
    "files.autoGuessEncoding": false,
    "files.eol": "\n",
    "files.insertFinalNewline": false,
    "files.trimFinalNewlines": true,
    "files.associations": {
        // Makefiles
        "Makefile.*": "makefile",
        // Markdown
        "*.md*": "markdown",
        // Configuration Files
        "*.jsonc": "jsonc",
        "*.json5": "jsonc",
        "*.yml": "yaml",
        "*.yaml": "yaml",
        "*.toml": "toml",
        // Programming Languages
        "*.js": "javascript",
        "*.jsx": "javascriptreact",
        "*.ts": "typescript",
        "*.tsx": "typescriptreact",
        "*.go": "go",
        "*.cs": "csharp",
        "*.html": "html",
        "*.css": "css",
        "*.scss": "scss",
        "*.less": "less",
        "*.py": "python",
        "*.rb": "ruby",
        "*.java": "java",
        "*.php": "php",
        "*.rs": "rust",
        "*.cpp": "cpp",
        "*.c": "c",
        "*.h": "cpp",
        "*.hpp": "cpp",
        "*.swift": "swift"
    },
    "files.exclude": {
        "**/.git": true,
        "**/.vs": true,
        "**/TestResults": true,
        "**/packages": true,
        "**/BenchmarkDotNet.Artifacts": true,
        "**/.sonarqube": true
    },

    // PERFORMANCE - Performance optimizations and exclusions
    // https://code.visualstudio.com/docs/setup/setup-overview#_advanced-functionality
    "files.watcherExclude": {
        "**/.git/**": true,
        "**/node_modules/**": true,
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/.vs/**": true,
        "**/TestResults/**": true,
        "**/packages/**": true,
        "**/dist/**": true,
        "**/build/**": true,
        "**/BenchmarkDotNet.Artifacts/**": true,
        "**/.sonarqube/**": true,
        "**/.bloop": true,
        "**/.metals": true,
        "**/target/**": true,
        "**/.next/**": true,
        "**/.nuxt/**": true,
        "**/.output/**": true,
        "**/.turbo/**": true,
        "**/.cache/**": true,
        "**/.parcel-cache/**": true,
        "**/.svelte-kit/**": true,
        "**/bin/**": true,
        "**/obj/**": true,
        "**/coverage/**": true,
        "**/.temp/**": true,
        "**/artifacts/**": true,
        "**/.venv/**": true
    },
    "search.exclude": {
        "**/.git": true,
        "**/node_modules": true,
        "**/.vs": true,
        "**/TestResults": true,
        "**/packages": true,
        "**/dist": true,
        "**/build": true,
        "**/BenchmarkDotNet.Artifacts": true,
        "**/.sonarqube": true,
        "**/target": true,
        "**/.next": true,
        "**/.nuxt": true,
        "**/.output": true,
        "**/.turbo": true,
        "**/.cache": true,
        "**/.parcel-cache": true,
        "**/.svelte-kit": true,
        "**/coverage": true,
        "**/.temp": true,
        "**/artifacts": true,
        "**/bin": true,
        "**/obj": true,
        "**/.venv": true
    },

    // VERSION CONTROL (GIT) - Integrated Git settings
    // https://code.visualstudio.com/docs/sourcecontrol/overview
    "git.enableSmartCommit": true,
    "git.autofetch": false,
    "git.openRepositoryInParentFolders": "never",
    "git.confirmSync": false,
    "git.decorations.enabled": true,
    "git.showPushSuccessNotification": true,
    "git.allowForcePush": false,
    "git.branchProtection": ["main", "master", "develop"],
    "git.detectWorktrees": false,
    "git.enabled": true,
    "git.autorefresh": true,
    "git.detectSubmodules": false,
    "git.detectSubmodulesLimit": 10,
    "scm.repositories.visible": 4,
    "scm.defaultViewMode": "tree",
    "scm.defaultViewSortKey": "name",
    "scm.repositories.sortOrder": "discovery time",

    // GITHUB - GitHub integration
    // https://code.visualstudio.com/docs/sourcecontrol/github
    "github.gitProtocol": "ssh",

    // REMOTE DEVELOPMENT - SSH, WSL and Remote Development
    // https://code.visualstudio.com/docs/remote/remote-overview
    "remote.WSL.useShellEnvironment": true,
    "remote.autoForwardPortsSource": "hybrid",
    "remote.extensionKind": {
        "alefragnani.project-manager": ["workspace", "ui"],
        "GitHub.copilot": ["workspace", "ui"],
        "GitHub.copilot-chat": ["workspace", "ui"],
        "GitHub.vscode-pull-request-github": ["workspace", "ui"],
        "ms-vscode-remote.remote-ssh": ["ui"],
        "esbenp.prettier-vscode": ["workspace"],
        "ms-dotnettools.csharp": ["workspace"],
        "golang.go": ["workspace"]
    },

    // EXTENSIONS - Extension management
    // https://code.visualstudio.com/docs/editor/extension-marketplace
    "extensions.autoUpdate": false,
    "extensions.ignoreRecommendations": false,
    "docker.extension.enableComposeLanguageServer": false,
    "jupyter.askForKernelRestart": false,

    // FORMATTERS - Specific formatter settings
    // https://prettier.io/docs/en/configuration.html
    // Prettier remains available for explicit use, but it is not the shared
    // default formatter because the repository EOF policy forbids final newlines.
    "prettier.endOfLine": "lf",
    "prettier.trailingComma": "es5",

    // LANGUAGE SETTINGS - Formatters and specific behaviors
    // https://code.visualstudio.com/docs/languages/overview

    // Go
    "[go]": {
        "editor.insertSpaces": false,
        "editor.formatOnSave": false,
        "editor.tabSize": 4,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "always"
        }
    },

    // C#
    "csharp.preview.improvedLaunchExperience": true,
    "[csharp]": {
        "files.encoding": "utf8",
        "editor.defaultFormatter": "ms-dotnettools.csharp"
    },

    // JavaScript / TypeScript
    "[javascript]": {
        "files.encoding": "utf8"
    },
    "[typescript]": {
        "files.encoding": "utf8"
    },

    // Web Technologies
    "[html]": {
        "files.encoding": "utf8"
    },
    "[css]": {
        "files.encoding": "utf8"
    },
    "[scss]": {
        "files.encoding": "utf8"
    },
    "[vue]": {
        "files.encoding": "utf8"
    },

    // Configuration Files
    "[json]": {
        "files.encoding": "utf8"
    },
    "json.schemas": [
        {
            "fileMatch": ["/.codex/orchestration/agents.manifest.json"],
            "url": "./.github/schemas/agent.contract.schema.json"
        },
        {
            "fileMatch": ["/.codex/orchestration/pipelines/default.pipeline.json"],
            "url": "./.github/schemas/agent.pipeline.schema.json"
        },
        {
            "fileMatch": ["/.codex/orchestration/templates/handoff.template.json"],
            "url": "./.github/schemas/agent.handoff.schema.json"
        },
        {
            "fileMatch": ["/.codex/orchestration/templates/run-artifact.template.json"],
            "url": "./.github/schemas/agent.run-artifact.schema.json"
        },
        {
            "fileMatch": ["/.codex/orchestration/evals/golden-tests.json"],
            "url": "./.github/schemas/agent.evals.schema.json"
        }
    ],
    "json.schemaDownload.trustedDomains": {
        "https://schemastore.azurewebsites.net/": true,
        "https://raw.githubusercontent.com/": true,
        "https://www.schemastore.org/": true,
        "https://json.schemastore.org/": true,
        "https://json-schema.org/": true,
        "https://biomejs.dev": true
    },
    "[yaml]": {
        "files.encoding": "utf8",
        "editor.defaultFormatter": "redhat.vscode-yaml",
        "editor.insertSpaces": true,
        "editor.tabSize": 2
    },

    // Documentation
    "[markdown]": {
        "files.encoding": "utf8",
        "editor.wordWrap": "wordWrapColumn",
        "editor.wordWrapColumn": 160,
        "files.insertFinalNewline": false,
        "editor.formatOnSave": false
    },

    // DEVELOPMENT TOOLS - ESLint, Copilot, Makefile and other tools
    // https://code.visualstudio.com/docs/languages/javascript#_linters
    "eslint.validate": [
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact",
        "vue"
    ],
    "eslint.codeActionsOnSave.mode": "problems",
    "eslint.codeAction.showDocumentation": {
        "enable": false
    },
    "eslint.codeAction.disableRuleComment": {
        "enable": false
    },

    // ═══════════════════════════════════════════════════════════════════════════════════════════════
    // COPILOT & AI CHAT CONFIGURATION
    // ═══════════════════════════════════════════════════════════════════════════════════════════════
    // Consolidated GitHub Copilot, AI Chat, and file reference settings.
    // Update paths below to point to your %USERPROFILE% shared instruction runtime.
    // ═══════════════════════════════════════════════════════════════════════════════════════════════

    // Copilot Enable Settings
    // https://code.visualstudio.com/docs/copilot/overview
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": true,
        "scminput": false
    },
    "github.copilot.advanced": {},
    "github.copilot.chat.localeOverride": "pt-br",
    "github.copilot.nextEditSuggestions.enabled": false,
    "github.copilot.chat.reviewSelection.enabled": false,
    "github.copilot.chat.codeGeneration.useInstructionFiles": true,
    "chatgpt.localeOverride": "pt-BR",

    // Chat & AI Configuration
    "chat.agent.maxRequests": 100,
    "chat.emptyState.history.enabled": false,
    "chat.restoreLastPanelSession": false,
    "chat.useAgentsMdFile": true,
    "chat.useNestedAgentsMdFiles": false,
    "chat.mcp.gallery.enabled": true,
    "chat.viewSessions.orientation": "stacked",
    "chat.hookFilesLocations": {
        ".github/hooks": true,
        "~/.github/hooks": true,
        ".claude/settings.json": false,
        ".claude/settings.local.json": false,
        "~/.claude/settings.json": false
    },

    // Chat instruction file locations - Folders containing .md instruction files
    // https://code.visualstudio.com/docs/copilot/customization
    "chat.instructionsFilesLocations": {
        "%USERPROFILE%\\.github\\": true
    },

    // Copilot Custom Instructions - File references for code review, commits, and PRs
    // https://code.visualstudio.com/docs/copilot/customization/custom-instructions
    "github.copilot.chat.reviewSelection.instructions": [
        { "file": "%USERPROFILE%\\.github\\AGENTS.md" },
        { "file": "%USERPROFILE%\\.github\\copilot-instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\process\\ntk-process-workflow-optimization.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\runtime-ops\\ntk-runtime-vscode-workspace-efficiency.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\runtime-ops\\ntk-runtime-powershell-execution.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\architecture\\backend\\ntk-backend-dotnet-csharp.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\architecture\\backend\\ntk-backend-architecture-core.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\data-security\\ntk-data-orm.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\architecture\\frontend\\ntk-frontend-architecture-core.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\architecture\\frontend\\ntk-frontend-vue-quasar.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\architecture\\frontend\\ntk-frontend-vue-quasar-architecture.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\architecture\\frontend\\ntk-frontend-ui-ux.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\data-security\\ntk-data-database.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\data-security\\ntk-data-orm.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\runtime-ops\\ntk-runtime-microservices-performance.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\runtime-ops\\ntk-runtime-static-analysis-sonarqube.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\runtime-ops\\ntk-runtime-docker.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\runtime-ops\\ntk-runtime-k8s.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\runtime-ops\\ntk-runtime-ci-cd-devops.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\process\\ntk-process-e2e-testing.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\architecture\\backend\\ntk-backend-rust-code-organization.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\process\\ntk-process-rust-testing.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\docs\\ntk-docs-readme.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\process\\ntk-process-feedback-changelog.instructions.md" },
        { "text": "Code suggestions must follow Clean Architecture: separation of concerns, dependency inversion, maintainability, readability and simplicity." }
    ],
    "github.copilot.chat.commitMessageGeneration.instructions": [
        { "file": "%USERPROFILE%\\.github\\AGENTS.md" },
        { "file": "%USERPROFILE%\\.github\\copilot-instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\process\\ntk-process-pr.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\docs\\ntk-docs-prompt-templates.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\docs\\ntk-docs-readme.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\process\\ntk-process-feedback-changelog.instructions.md" },
        { "text": "Commit messages: Conventional Commits (feat, fix, docs, refactor, test, chore), English, imperative mood, max 72 chars." }
    ],
    "github.copilot.chat.pullRequestDescriptionGeneration.instructions": [
        { "file": "%USERPROFILE%\\.github\\AGENTS.md" },
        { "file": "%USERPROFILE%\\.github\\copilot-instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\process\\ntk-process-pr.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\docs\\ntk-docs-readme.instructions.md" },
        { "file": "%USERPROFILE%\\.github\\instructions\\process\\ntk-process-feedback-changelog.instructions.md" },
        { "text": "PR description must include: Context, Changes, Rationale, Risks, Testing, Docs, Breaking Changes, Migration." }
    ],

    // ═══════════════════════════════════════════════════════════════════════════════════════════════
