{
  "version": 1,
  "requiredFiles": [
    "CODEOWNERS",
    "CHANGELOG.md",
    "definitions/providers/github/root/AGENTS.md",
    "definitions/providers/github/root/copilot-instructions.md",
    ".github/policies/instruction-system.policy.json",
    "definitions/providers/github/governance/validation-profiles.json",
    "definitions/providers/github/governance/agent-skill-permissions.matrix.json",
    "definitions/providers/github/governance/supply-chain.baseline.json",
    "definitions/providers/github/governance/warning-baseline.json",
    "definitions/providers/github/governance/shared-script-checksums.manifest.json",
    ".github/runbooks/README.md",
    "crates/cli/src/validation_commands.rs",
    "crates/commands/validation/src/agent_orchestration/agent_permissions.rs",
    "crates/commands/validation/src/orchestration/validate_all.rs",
    "crates/commands/validation/src/security/security_baseline.rs",
    "crates/commands/validation/src/security/supply_chain.rs",
    "definitions/providers/github/hooks/super-agent.bootstrap.json",
    "definitions/providers/github/hooks/scripts/common.ps1",
    "definitions/providers/github/hooks/scripts/session-start.ps1",
    "definitions/providers/github/hooks/scripts/subagent-start.ps1",
    ".githooks/pre-commit",
    ".githooks/post-commit",
    ".githooks/post-merge",
    ".githooks/post-checkout",
    "crates/commands/validation/src/governance/template_standards.rs",
    "crates/commands/validation/src/workspace/workspace_efficiency.rs",
    "crates/commands/validation/src/agent_orchestration/agent_hooks.rs",
    "crates/commands/validation/src/operational_hygiene/shell_hooks.rs",
    "crates/commands/validation/src/operational_hygiene/runtime_script_tests.rs",
    "scripts/tests/runtime/runtime-scripts.tests.ps1",
    "scripts/tests/runtime/compatibility-lifecycle.tests.ps1",
    "scripts/tests/runtime/template-standards.tests.ps1"
    ,
    "scripts/tests/runtime/workspace-efficiency.tests.ps1"
  ],
  "requiredDirectories": [
    "definitions/providers/github/hooks",
    ".github/policies",
    "definitions/providers/github/governance",
    "scripts/validation"
  ],
  "scanExtensions": [
    ".md",
    ".txt",
    ".json",
    ".jsonc",
    ".yml",
    ".yaml",
    ".toml",
    ".ps1",
    ".psm1",
    ".cs",
    ".props",
    ".targets",
    ".xml",
    ".ts",
    ".tsx",
    ".js",
    ".jsx",
    ".cmd",
    ".bat",
    ".sh"
  ],
  "excludedPathGlobs": [
    ".git/**",
    ".temp/**",
    "**/bin/**",
    "**/obj/**",
    "**/.vs/**",
    "**/.vscode-test/**",
    "**/*.sln"
  ],
  "forbiddenPathGlobs": [
    "**/*.pfx",
    "**/*.p12",
    "**/*.key",
    "**/*.pem",
    "**/id_rsa",
    "**/id_ed25519"
  ],
  "forbiddenContentPatterns": [
    {
      "id": "github-classic-pat",
      "pattern": "ghp_[A-Za-z0-9]{36}",
      "severity": "failure"
    },
    {
      "id": "github-fine-grained-pat",
      "pattern": "github_pat_[A-Za-z0-9_]{80,}",
      "severity": "failure"
    },
    {
      "id": "aws-access-key-id",
      "pattern": "AKIA[0-9A-Z]{16}",
      "severity": "failure"
    },
    {
      "id": "private-key-block",
      "pattern": "-----BEGIN (?:RSA|EC|DSA|OPENSSH|PRIVATE) KEY-----",
      "severity": "failure"
    },
    {
      "id": "hardcoded-password-assignment",
      "pattern": "(?i)(password|passwd|pwd)\\s*[:=]\\s*[\"'](?!\\*{3}|changeme|password|example|your-password)[^\"']{8,}[\"']",
      "severity": "warning"
    },
    {
      "id": "inline-bearer-token",
      "pattern": "(?i)authorization\\s*[:=]\\s*[\"']?bearer\\s+[A-Za-z0-9\\-_.]{20,}",
      "severity": "warning"
    }
  ],
  "allowedContentPatterns": [
    "(?i)example-token",
    "(?i)example-password",
    "(?i)sample-secret"
  ]
}