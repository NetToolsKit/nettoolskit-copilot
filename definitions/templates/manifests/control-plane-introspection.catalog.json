{
  "apiVersion": "ntk/v1",
  "kind": "control-plane-introspection-catalog",
  "title": "NetToolsKit Control-Plane Introspection Catalog",
  "schemaVersion": 1,
  "surfaces": [
    {
      "id": "ai-doctor",
      "schemaKind": "ai_doctor",
      "entryPoints": ["ntk ai doctor --json-output"],
      "owner": "crates/orchestrator/src/execution/ai_doctor.rs",
      "contractType": "machine-readable diagnostics",
      "guarantees": [
        "stable schema version",
        "provider/profile/routing readiness",
        "adapter contract summary",
        "lane-aware model-routing state"
      ]
    },
    {
      "id": "ai-provider-profiles",
      "schemaKind": "ai_provider_profiles",
      "entryPoints": ["ntk ai profiles list --json-output"],
      "owner": "crates/orchestrator/src/execution/ai_profiles.rs",
      "contractType": "machine-readable control inventory",
      "guarantees": [
        "stable schema version",
        "active profile env/source context",
        "full built-in profile inventory",
        "renderer-independent profile metadata"
      ]
    },
    {
      "id": "ai-provider-profile",
      "schemaKind": "ai_provider_profile",
      "entryPoints": ["ntk ai profiles show --json-output"],
      "owner": "crates/orchestrator/src/execution/ai_profiles.rs",
      "contractType": "machine-readable control inventory",
      "guarantees": [
        "stable schema version",
        "requested-profile echo",
        "resolved source attribution",
        "full built-in profile detail"
      ]
    },
    {
      "id": "runtime-doctor",
      "schemaKind": "runtime_doctor",
      "entryPoints": ["ntk runtime doctor --json-output"],
      "owner": "crates/commands/runtime/src/diagnostics/doctor.rs",
      "contractType": "machine-readable diagnostics",
      "guarantees": [
        "stable schema version",
        "projection drift state",
        "mapping counts and detailed file lists",
        "sync-attempt and sync-resolution state"
      ]
    },
    {
      "id": "runtime-healthcheck",
      "schemaKind": "runtime_healthcheck",
      "entryPoints": ["ntk runtime healthcheck --json-output"],
      "owner": "crates/commands/runtime/src/diagnostics/healthcheck.rs",
      "contractType": "machine-readable diagnostics",
      "guarantees": [
        "stable schema version",
        "runtime health summary counts",
        "typed executed-check state",
        "warning-mode and drift-policy options"
      ]
    },
    {
      "id": "runtime-self-heal",
      "schemaKind": "runtime_self_heal",
      "entryPoints": ["ntk runtime self-heal --json-output"],
      "owner": "crates/commands/runtime/src/diagnostics/self_heal.rs",
      "contractType": "machine-readable diagnostics",
      "guarantees": [
        "stable schema version",
        "typed repair-step state",
        "follow-up healthcheck linkage",
        "explicit bootstrap/template option flags"
      ]
    },
    {
      "id": "local-context-query",
      "schemaKind": "local_context_query",
      "entryPoints": ["ntk runtime query-local-context-index --json-output"],
      "owner": "crates/commands/runtime/src/continuity/local_context.rs",
      "contractType": "machine-readable continuity recall",
      "guarantees": [
        "stable schema version",
        "typed backend label",
        "explicit compatibility-index and sqlite-memory paths",
        "ranked local-context hits"
      ]
    },
    {
      "id": "local-memory-query",
      "schemaKind": "local_memory_query",
      "entryPoints": ["ntk runtime query-local-memory --json-output"],
      "owner": "crates/commands/runtime/src/continuity/local_context.rs",
      "contractType": "machine-readable continuity recall",
      "guarantees": [
        "stable schema version",
        "explicit sqlite-memory path",
        "ranked local-memory hits",
        "renderer-independent query metadata"
      ]
    }
  ],
  "evolutionRules": {
    "versionField": "schema_version",
    "kindField": "schema_kind",
    "breakingChangePolicy": "increment schemaVersion before removing or renaming fields",
    "rendererRule": "CLI human output may change independently; machine-readable output must remain bound to the typed contract"
  }
}