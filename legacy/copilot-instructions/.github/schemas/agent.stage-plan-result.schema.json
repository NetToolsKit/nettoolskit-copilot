{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/agent.stage-plan-result.schema.json",
  "title": "Planner Stage Result",
  "type": "object",
  "required": [
    "objective",
    "scopeSummary",
    "assumptions",
    "acceptanceCriteria",
    "workItems",
    "contextPaths",
    "validations",
    "risks",
    "deliverySlices"
  ],
  "additionalProperties": false,
  "properties": {
    "objective": { "type": "string", "minLength": 1 },
    "scopeSummary": { "type": "string", "minLength": 1 },
    "assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "workItems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "description",
          "allowedPaths",
          "targetPaths",
          "commands",
          "checkpoints",
          "commitCheckpoint",
          "deliverables",
          "validationSteps",
          "successCriteria"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]{2,64}$" },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "dependsOn": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z0-9-]{2,64}$" },
            "uniqueItems": true
          },
          "allowedPaths": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "targetPaths": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "commands": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["purpose", "command"],
              "additionalProperties": false,
              "properties": {
                "purpose": { "type": "string", "minLength": 1 },
                "command": { "type": "string", "minLength": 1 },
                "expectedOutcome": { "type": "string", "minLength": 1 }
              }
            }
          },
          "checkpoints": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "expectedOutcome", "evidence"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "expectedOutcome": {
                  "type": "string",
                  "enum": ["expected-fail", "expected-pass", "expected-verified"]
                },
                "evidence": { "type": "string", "minLength": 1 },
                "command": { "type": "string", "minLength": 1 }
              }
            }
          },
          "commitCheckpoint": {
            "type": "object",
            "required": ["scope", "when", "suggestedMessage"],
            "additionalProperties": false,
            "properties": {
              "scope": {
                "type": "string",
                "enum": ["task", "slice", "final"]
              },
              "when": { "type": "string", "minLength": 1 },
              "suggestedMessage": { "type": "string", "minLength": 1 }
            }
          },
          "deliverables": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "validationSteps": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "successCriteria": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "contextPaths": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "validations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "deliverySlices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "goal"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "goal": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}