{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/agent.checkpoint-state.schema.json",
  "title": "Agent Checkpoint State",
  "type": "object",
  "required": ["traceId", "pipelineId", "startedAt", "updatedAt", "status", "lastSuccessfulStageId", "resumableFromStageId", "stages"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "traceId": { "type": "string", "pattern": "^[a-zA-Z0-9-]{8,128}$" },
    "pipelineId": { "type": "string", "pattern": "^[a-z0-9-]{2,64}$" },
    "startedAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["running", "success", "failed", "partial"] },
    "lastSuccessfulStageId": { "type": "string" },
    "resumableFromStageId": { "type": "string" },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stageId", "stageIndex", "status", "checkpointEligible", "updatedAt"],
        "additionalProperties": false,
        "properties": {
          "stageId": { "type": "string", "pattern": "^[a-z0-9-]{2,64}$" },
          "stageIndex": { "type": "integer", "minimum": 0 },
          "status": { "type": "string", "enum": ["success", "failed", "skipped", "partial"] },
          "checkpointEligible": { "type": "boolean" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}