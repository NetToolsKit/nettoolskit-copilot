<?xml version="1.0" encoding="UTF-8"?>
<!--
  Template: Unit Test Generator (POML)
  Purpose: Generate comprehensive xUnit/NUnit tests following AAA pattern
  Version: 1.0.0
  Owner: Quality Engineering Team
  Updated: 2025-11-15
-->
<prompt>
  <meta
    version="1.0.0"
    owner="quality-engineering"
    updated="2025-11-15"
    llm="gpt-4"
    temperature="0.3"
    maxTokens="2000"
    costTarget="0.02"
    latencyTarget="5s"
  />

  <role>Senior test engineer with expertise in .NET testing frameworks, Clean Architecture, and TDD/BDD practices.</role>

  <task>
    Generate comprehensive unit tests for .NET classes following AAA (Arrange-Act-Assert) pattern.
    Create tests covering valid inputs, invalid inputs, edge cases, and exception scenarios.
  </task>

  <context>
    <documents>
      <variable name="classUnderTest" type="string" required="true" />
      <variable name="testFramework" type="enum" values="xUnit,NUnit" required="true" default="xUnit" />
      <variable name="sourceCode" type="string" required="true" />
      <variable name="dependencies" type="array" required="false" />
    </documents>
  </context>

  <constraints>
    <item>Follow AAA pattern strictly (Arrange, Act, Assert)</item>
    <item>Use [Trait("Category", "Unit")] for xUnit or [Category("Unit")] for NUnit</item>
    <item>Name tests: MethodName_Scenario_ExpectedResult</item>
    <item>Use native xUnit/NUnit assertions (Assert.Equal, Assert.True, etc.)</item>
    <item>Mock dependencies with NSubstitute</item>
    <item>Organize with #region directives per method</item>
    <item>Include XML documentation for test classes</item>
    <item>Tests must be deterministic and fast (< 100ms)</item>
    <item>One assertion per test (SRP for tests)</item>
    <item>Use test data builders for complex objects</item>
  </constraints>

  <output format="csharp">
using System;
using Xunit; // or NUnit.Framework
using NSubstitute;

namespace {{Namespace}}.Tests;

/// &lt;summary&gt;
/// Unit tests for &lt;see cref="{{ClassName}}"/&gt;.
/// &lt;/summary&gt;
[Trait("Category", "Unit")]
public class {{ClassName}}Tests
{
    #region Test Methods - {{MethodName}} Valid Cases

    [Fact]
    public void {{MethodName}}_WithValidInput_ReturnsExpectedResult()
    {
        // Arrange
        {{arrange}}

        // Act
        {{act}}

        // Assert
        {{assert}}
    }

    #endregion

    #region Test Methods - {{MethodName}} Invalid Cases

    [Fact]
    public void {{MethodName}}_WithInvalidInput_ThrowsArgumentException()
    {
        // Arrange
        {{arrange}}

        // Act & Assert
        var ex = Assert.Throws&lt;ArgumentException&gt;(() => {{act}});
        Assert.Contains("{{expectedMessage}}", ex.Message);
    }

    #endregion

    #region Test Methods - {{MethodName}} Edge Cases

    [Theory]
    [InlineData({{testData}})]
    public void {{MethodName}}_WithEdgeCase_HandlesCorrectly({{parameters}})
    {
        // Arrange
        {{arrange}}

        // Act
        {{act}}

        // Assert
        {{assert}}
    }

    #endregion
}
  </output>

  <examples>
    <example>
      <input>
        <classUnderTest>OrderService</classUnderTest>
        <testFramework>xUnit</testFramework>
        <sourceCode>
public class OrderService
{
    public decimal CalculateTotal(Order order)
    {
        if (order == null) throw new ArgumentNullException(nameof(order));
        return order.Items.Sum(i => i.Price * i.Quantity);
    }
}
        </sourceCode>
      </input>
      <output>
using System;
using Xunit;

namespace Services.Tests;

/// &lt;summary&gt;
/// Unit tests for &lt;see cref="OrderService"/&gt;.
/// &lt;/summary&gt;
[Trait("Category", "Unit")]
public class OrderServiceTests
{
    #region Test Methods - CalculateTotal Valid Cases

    [Fact]
    public void CalculateTotal_WithValidOrder_ReturnsCorrectSum()
    {
        // Arrange
        var service = new OrderService();
        var order = new Order
        {
            Items = new[]
            {
                new OrderItem { Price = 10.00m, Quantity = 2 },
                new OrderItem { Price = 5.00m, Quantity = 3 }
            }
        };

        // Act
        var result = service.CalculateTotal(order);

        // Assert
        Assert.Equal(35.00m, result);
    }

    #endregion

    #region Test Methods - CalculateTotal Invalid Cases

    [Fact]
    public void CalculateTotal_WithNullOrder_ThrowsArgumentNullException()
    {
        // Arrange
        var service = new OrderService();

        // Act & Assert
        var ex = Assert.Throws&lt;ArgumentNullException&gt;(() => service.CalculateTotal(null));
        Assert.Equal("order", ex.ParamName);
    }

    #endregion

    #region Test Methods - CalculateTotal Edge Cases

    [Fact]
    public void CalculateTotal_WithEmptyItems_ReturnsZero()
    {
        // Arrange
        var service = new OrderService();
        var order = new Order { Items = Array.Empty&lt;OrderItem&gt;() };

        // Act
        var result = service.CalculateTotal(order);

        // Assert
        Assert.Equal(0m, result);
    }

    #endregion
}
      </output>
    </example>
  </examples>

  <notes>
    Coverage areas to generate:
    1. Valid inputs: Happy path scenarios
    2. Invalid inputs: Null, empty, malformed data
    3. Edge cases: Boundary conditions, special values
    4. Exception scenarios: Error handling validation

    Framework-specific attributes:
    - xUnit: [Fact], [Theory], [InlineData], [MemberData]
    - NUnit: [Test], [TestCase], [TestCaseSource]

    References:
    - .github/templates/dotnet-unit-test-template.cs
    - .github/instructions/dotnet-csharp.instructions.md
    - .github/instructions/clean-architecture-code.instructions.md
  </notes>
</prompt>
