{
  "name": "Base",
  "description": "Perfil mínimo: Copilot, Git, temas, utilitários. Herança para todos os outros profiles.",
  "extensions": [
    "github.copilot-chat",
    "anthropic.claude-code",
    "mhutchie.git-graph",
    "pkief.material-icon-theme",
    "ms-ceintl.vscode-language-pack-pt-br",
    "editorconfig.editorconfig",
    "gruntfuggly.todo-tree",
    "oderwat.indent-rainbow",
    "naumovs.color-highlight",
    "adpyke.codesnap",
    "redhat.vscode-yaml",
    "ms-vscode.powershell",
    "ms-vscode-remote.remote-ssh",
    "ms-vscode-remote.remote-ssh-edit",
    "ms-vscode-remote.remote-wsl",
    "ms-vscode-remote.remote-containers",
    "ms-vscode.remote-explorer",
    "tomoki1207.pdf",
    "yzane.markdown-pdf",
    "mechatroner.rainbow-csv"
  ],
  "mcp": {
    "servers": {
      "io.github.github/github-mcp-server": { "enabled": true },
      "microsoftdocs/mcp":                  { "enabled": true },
      "microsoft/playwright-mcp":           { "enabled": false },
      "com.microsoft/nuget":                { "enabled": false },
      "com.microsoft/azure":                { "enabled": false }
    }
  }
}