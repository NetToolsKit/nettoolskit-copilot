    // MCP Servers - Model Context Protocol for extended Copilot capabilities
    // https://modelcontextprotocol.io/
    "github.copilot.chat.mcp.servers": {
        // .NET Development
        "dotnet-sdk": {
            "command": "dotnet",
            "args": ["--info"],
            "description": ".NET SDK information and version management"
        },
        "dotnet-ef": {
            "command": "dotnet",
            "args": ["ef", "--help"],
            "description": "Entity Framework Core migrations and database management"
        },
        
        // Node.js / Frontend Tools
        "npm": {
            "command": "npm",
            "args": ["--version"],
            "description": "Node Package Manager"
