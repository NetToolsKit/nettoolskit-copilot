{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/mcp-runtime.catalog.schema.json",
  "title": "MCP Runtime Catalog",
  "type": "object",
  "required": ["version", "inputs", "servers"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/input" }
    },
    "servers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/server" }
    }
  },
  "$defs": {
    "input": {
      "type": "object",
      "required": ["id", "type", "description", "password"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "password": { "type": "boolean" }
      }
    },
    "target": {
      "type": "object",
      "required": ["include"],
      "additionalProperties": false,
      "properties": {
        "include": { "type": "boolean" },
        "enabledByDefault": { "type": "boolean" }
      }
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "definition": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "command": { "type": "string" },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        },
        "url": { "type": "string" },
        "headers": { "$ref": "#/$defs/stringMap" },
        "env": { "$ref": "#/$defs/stringMap" },
        "gallery": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "vscode": { "$ref": "#/$defs/target" },
        "codex": { "$ref": "#/$defs/target" },
        "claude": { "$ref": "#/$defs/target" }
      }
    },
    "server": {
      "type": "object",
      "required": ["id", "targets", "definition"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "codexName": { "type": "string" },
        "targets": { "$ref": "#/$defs/targets" },
        "definition": { "$ref": "#/$defs/definition" }
      }
    }
  }
}