{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/agent.stage-spec-result.schema.json",
  "title": "Specification Stage Result",
  "type": "object",
  "required": [
    "stage",
    "status",
    "specRequired",
    "workstreamSlug",
    "specSummary",
    "designDecisions",
    "alternativesConsidered",
    "assumptions",
    "risks",
    "acceptanceCriteria",
    "planningReadiness",
    "recommendedSpecialists",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "stage": { "type": "string", "const": "brainstorm-spec" },
    "status": { "type": "string", "enum": ["required", "not-required"] },
    "specRequired": { "type": "boolean" },
    "workstreamSlug": { "type": "string", "pattern": "^[a-z0-9-]{1,64}$" },
    "specSummary": { "type": "string", "minLength": 1 },
    "designDecisions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "alternativesConsidered": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "planningReadiness": { "type": "string", "enum": ["ready-for-plan", "not-needed"] },
    "recommendedSpecialists": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}