{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/agent.run-artifact.schema.json",
  "title": "Multi-Agent Run Artifact",
  "type": "object",
  "required": [
    "traceId",
    "pipelineId",
    "status",
    "startedAt",
    "finishedAt",
    "stages",
    "summary"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "traceId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-]{8,128}$"
    },
    "pipelineId": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,64}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failed",
        "partial"
      ]
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "finishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stageRun"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "approvals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/approval"
      }
    }
  },
  "$defs": {
    "stageRun": {
      "type": "object",
      "required": [
        "stageId",
        "agentId",
        "status",
        "startedAt",
        "finishedAt",
        "durationMs",
        "inputArtifacts",
        "outputArtifacts"
      ],
      "additionalProperties": false,
      "properties": {
        "stageId": {
          "type": "string",
          "pattern": "^[a-z0-9-]{2,64}$"
        },
        "agentId": {
          "type": "string",
          "pattern": "^[a-z0-9-]{2,64}$"
        },
        "status": {
          "type": "string",
          "enum": [
            "success",
            "failed",
            "skipped",
            "partial"
          ]
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "finishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0
        },
        "inputArtifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputArtifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "warnings": {
              "type": "integer",
              "minimum": 0
            },
            "failures": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "execution": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "backend": {
              "type": "string"
            },
            "attempts": {
              "type": "integer",
              "minimum": 0
            },
            "dispatchMode": {
              "type": "string"
            },
            "promptTemplatePath": {
              "type": [
                "string",
                "null"
              ]
            },
            "responseSchemaPath": {
              "type": [
                "string",
                "null"
              ]
            },
            "dispatchCount": {
              "type": "integer",
              "minimum": 0
            },
            "workItemCount": {
              "type": "integer",
              "minimum": 0
            },
            "changedFileCount": {
              "type": "integer",
              "minimum": 0
            },
            "stageStatePath": {
              "type": [
                "string",
                "null"
              ]
            },
            "approvalRequired": {
              "type": "boolean"
            },
            "approvalSatisfied": {
              "type": "boolean"
            },
            "approvalRecordPath": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      }
    },
    "approval": {
      "type": "object",
      "required": [
        "scope",
        "targetId",
        "approvedBy",
        "justification"
      ],
      "additionalProperties": false,
      "properties": {
        "scope": {
          "type": "string",
          "enum": [
            "stage",
            "agent"
          ]
        },
        "targetId": {
          "type": "string",
          "pattern": "^[a-z0-9-]{2,64}$"
        },
        "approvedBy": {
          "type": "string",
          "minLength": 1
        },
        "justification": {
          "type": "string",
          "minLength": 1
        },
        "recordedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "stageCount",
        "failedStages",
        "warningCount",
        "estimatedCostUsd",
        "totalDurationMs"
      ],
      "additionalProperties": false,
      "properties": {
        "stageCount": {
          "type": "integer",
          "minimum": 1
        },
        "failedStages": {
          "type": "integer",
          "minimum": 0
        },
        "warningCount": {
          "type": "integer",
          "minimum": 0
        },
        "estimatedCostUsd": {
          "type": "number",
          "minimum": 0
        },
        "totalDurationMs": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}