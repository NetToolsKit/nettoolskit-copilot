{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/provider-surface-projection.catalog.schema.json",
  "title": "Provider Surface Projection Catalog",
  "type": "object",
  "required": ["version", "renderers", "surfaces"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "renderers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/renderer" }
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/surface" }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "bootstrap": {
      "type": "object",
      "required": ["enabled", "order", "condition"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "order": { "type": "integer", "minimum": 0 },
        "condition": {
          "type": "string",
          "enum": ["always", "codex", "claude", "never"]
        }
      }
    },
    "consumerFlag": {
      "type": "object",
      "required": ["enabled"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "order": { "type": "integer", "minimum": 0 }
      }
    },
    "rendererArgs": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "type": "boolean" },
          { "type": "integer" },
          { "$ref": "#/$defs/stringArray" }
        ]
      }
    },
    "rendererConsumers": {
      "type": "object",
      "required": ["bootstrap", "direct"],
      "additionalProperties": false,
      "properties": {
        "bootstrap": { "$ref": "#/$defs/bootstrap" },
        "direct": { "$ref": "#/$defs/consumerFlag" },
        "claudeSkillSync": { "$ref": "#/$defs/consumerFlag" }
      }
    },
    "renderer": {
      "type": "object",
      "required": ["id", "scriptPath", "description", "consumers"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "scriptPath": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "defaultArgs": { "$ref": "#/$defs/rendererArgs" },
        "consumers": { "$ref": "#/$defs/rendererConsumers" }
      }
    },
    "validation": {
      "type": "object",
      "required": ["enabled", "mode"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "mode": {
          "type": "string",
          "enum": ["directory", "selectedFiles", "generatedCatalogMcp", "skip"]
        },
        "fileNames": { "$ref": "#/$defs/stringArray" }
      }
    },
    "surface": {
      "type": "object",
      "required": ["id", "provider", "authority", "sourcePath", "projectedPath", "rendererId", "validation", "description"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "provider": { "type": "string", "minLength": 1 },
        "authority": {
          "type": "string",
          "enum": ["definitions", "generated"]
        },
        "sourcePath": { "type": "string", "minLength": 1 },
        "projectedPath": { "type": "string", "minLength": 1 },
        "rendererId": { "type": "string", "minLength": 1 },
        "validation": { "$ref": "#/$defs/validation" },
        "description": { "type": "string", "minLength": 1 },
        "repoTracked": { "type": "boolean" }
      }
    }
  }
}