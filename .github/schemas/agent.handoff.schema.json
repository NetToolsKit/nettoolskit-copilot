{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/agent.handoff.schema.json",
  "title": "Multi-Agent Stage Handoff Artifact",
  "type": "object",
  "required": [
    "traceId",
    "pipelineId",
    "fromStage",
    "toStage",
    "producedAt",
    "summary",
    "artifacts"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "traceId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-]{8,128}$"
    },
    "pipelineId": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,64}$"
    },
    "fromStage": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,64}$"
    },
    "toStage": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,64}$"
    },
    "producedAt": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "openQuestions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "required": [
        "name",
        "path"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "checksum": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}