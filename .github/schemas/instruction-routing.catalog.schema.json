{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/instruction-routing.catalog.schema.json",
  "title": "Instruction Routing Catalog",
  "type": "object",
  "required": ["version", "owner", "always", "routing"],
  "additionalProperties": true,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "always": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path"],
        "additionalProperties": true,
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "reason": { "type": "string" }
        }
      }
    },
    "routing": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "tags", "triggers", "include"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "tags": { "type": "array", "items": { "type": "string" } },
          "triggers": { "type": "array", "items": { "type": "string" } },
          "include": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path"],
              "additionalProperties": true,
              "properties": {
                "path": { "type": "string", "minLength": 1 },
                "reason": { "type": "string" },
                "when": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "prompts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "tags": { "type": "array", "items": { "type": "string" } },
          "purpose": { "type": "string" }
        }
      }
    }
  }
}