{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/agent.stage-route-result.schema.json",
  "title": "Route Stage Result",
  "type": "object",
  "required": [
    "summary",
    "recommendedSpecialistSkill",
    "recommendedSpecialistFocus",
    "contextPaths",
    "tokenBudgetGuidance",
    "executionNotes",
    "validationFocus",
    "closeoutExpectations",
    "shouldRunTester"
  ],
  "additionalProperties": false,
  "properties": {
    "summary": { "type": "string", "minLength": 1 },
    "recommendedSpecialistSkill": { "type": "string", "pattern": "^[a-z0-9-]{2,64}$" },
    "recommendedSpecialistFocus": { "type": "string", "minLength": 1 },
    "contextPaths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "tokenBudgetGuidance": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "executionNotes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "validationFocus": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "closeoutExpectations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "shouldRunTester": { "type": "boolean" },
    "readmeImpact": { "type": "boolean" },
    "changelogImpact": { "type": "boolean" }
  }
}