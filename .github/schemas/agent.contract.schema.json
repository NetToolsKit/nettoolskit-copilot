{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/agent.contract.schema.json",
  "title": "Multi-Agent Contract Manifest",
  "type": "object",
  "required": [
    "version",
    "owner",
    "agents"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxRetries": { "type": "integer", "minimum": 0, "maximum": 10 },
        "timeoutMinutes": { "type": "integer", "minimum": 1 },
        "approvalRequired": { "type": "boolean" }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/agent" }
    }
  },
  "$defs": {
    "budget": {
      "type": "object",
      "required": ["maxSteps", "maxDurationMinutes", "maxFileEdits", "maxTokens"],
      "additionalProperties": false,
      "properties": {
        "maxSteps": { "type": "integer", "minimum": 1 },
        "maxDurationMinutes": { "type": "integer", "minimum": 1 },
        "maxFileEdits": { "type": "integer", "minimum": 1 },
        "maxTokens": { "type": "integer", "minimum": 1000 }
      }
    },
    "agent": {
      "type": "object",
      "required": ["id", "displayName", "role", "skill", "model", "tools", "allowedPaths", "budget"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]{2,64}$" },
        "displayName": { "type": "string", "minLength": 1 },
        "role": {
          "type": "string",
          "enum": ["planner", "router", "specialist", "tester", "reviewer", "release"]
        },
        "skill": { "type": "string", "pattern": "^[a-z0-9-]{2,64}$" },
        "model": { "type": "string", "minLength": 1 },
        "tools": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "allowedPaths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "blockedCommands": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "budget": { "$ref": "#/$defs/budget" },
        "fallbackAgentId": { "type": "string", "pattern": "^[a-z0-9-]{2,64}$" },
        "notes": { "type": "string" }
      }
    }
  }
}