{
  "version": 1,
  "intentionalGlobalExceptions": [
    {
      "concern": "Agent selection, mandatory context bootstrap, and instruction precedence must remain globally visible.",
      "ownedBy": "global-core"
    },
    {
      "concern": "Enterprise-first default behavior and universal execution quality gates must remain globally visible.",
      "ownedBy": "global-core"
    },
    {
      "concern": "Repository-level routing entry point and minimal-context contract must remain globally visible.",
      "ownedBy": "global-core"
    },
    {
      "concern": "Super Agent lifecycle orchestration must remain globally visible so change-bearing work cannot bypass planning, testing, review, or closeout.",
      "ownedBy": "global-core"
    }
  ],
  "architectureConstraints": {
    "globalCoreMaxChars": {
      "AGENTS.md": 14000,
      "copilot-instructions.md": 14000
    },
    "routing": {
      "maxAlwaysFiles": 10,
      "maxSelectedFiles": 5,
      "requiredAlwaysPaths": [
        "AGENTS.md",
        "copilot-instructions.md",
        "instructions/core/ntk-core-super-agent.instructions.md",
        "instructions/core/ntk-core-repository-operating-model.instructions.md",
        "instructions/core/ntk-core-artifact-layout.instructions.md",
        "instructions/process/ntk-process-subagent-planning-workflow.instructions.md",
        "instructions/process/ntk-process-workflow-optimization.instructions.md",
        "instructions/core/ntk-core-authoritative-sources.instructions.md",
        "instructions/runtime-ops/ntk-runtime-powershell-execution.instructions.md",
        "instructions/process/ntk-process-feedback-changelog.instructions.md"
      ]
    }
  },
  "projectionContract": {
    "canonicalInstructionRoot": "definitions/shared/instructions",
    "projectedInstructionRoot": ".github/instructions",
    "providerRoots": [
      "definitions/providers/github/root",
      "definitions/providers/vscode/workspace",
      "definitions/providers/codex",
      "definitions/providers/claude"
    ],
    "naming": {
      "folderPolicy": "semantic-domain-folders",
      "disallowNumericPrefixes": true,
      "filePrefix": "ntk-"
    },
    "driftRules": [
      "Treat definitions/shared/instructions as the canonical instruction content for repo-owned guidance.",
      "Treat .github/instructions as the projected runtime surface; keep folder taxonomy and filenames aligned with canonical content.",
      "Update provider surfaces only after canonical and projected instruction paths are stable.",
      "Do not sync from the external copilot-instructions repository by blind overwrite; review drift explicitly and record intentional divergences."
    ]
  },
  "layers": [
    {
      "id": "global-core",
      "description": "Thin global context and execution contract loaded first for every task.",
      "pathPatterns": [
        ".github/AGENTS.md",
        ".github/copilot-instructions.md"
      ],
      "mustReference": [
        "instructions/core/ntk-core-repository-operating-model.instructions.md",
        "instructions/core/ntk-core-authoritative-sources.instructions.md",
        "instructions/core/ntk-core-artifact-layout.instructions.md"
      ]
    },
    {
      "id": "repository-operating-model",
      "description": "Repository-specific operational rules, commands, style, release, and domain instruction map.",
      "pathPatterns": [
        ".github/instructions/core/ntk-core-repository-operating-model.instructions.md"
      ]
    },
    {
      "id": "cross-cutting-policies",
      "description": "Policies, maps, and baselines that apply across domains.",
      "pathPatterns": [
        ".github/instructions/core/ntk-core-super-agent.instructions.md",
        ".github/instructions/core/ntk-core-authoritative-sources.instructions.md",
        ".github/governance/*",
        ".github/policies/*"
      ]
    },
    {
      "id": "domain-instructions",
      "description": "Semantic domain rules grouped by responsibility instead of flat or numbered ordering.",
      "pathPatterns": [
        ".github/instructions/process/*.instructions.md",
        ".github/instructions/architecture/backend/*.instructions.md",
        ".github/instructions/architecture/frontend/*.instructions.md",
        ".github/instructions/architecture/agentic/*.instructions.md",
        ".github/instructions/runtime-ops/*.instructions.md",
        ".github/instructions/data/*.instructions.md",
        ".github/instructions/security/*.instructions.md",
        ".github/instructions/docs/*.instructions.md"
      ],
      "excludePatterns": [
        ".github/instructions/core/ntk-core-authoritative-sources.instructions.md",
        ".github/instructions/core/ntk-core-super-agent.instructions.md",
        ".github/instructions/core/ntk-core-repository-operating-model.instructions.md"
      ]
    },
    {
      "id": "prompts",
      "description": "Operational prompt helpers used for routing and generation.",
      "pathPatterns": [
        ".github/prompts/*"
      ],
      "forbiddenOwnershipMarkers": [
        "single source of truth",
        "global rules live here",
        "always applied"
      ]
    },
    {
      "id": "templates",
      "description": "Concrete artifact skeletons that must not become normative policy owners.",
      "pathPatterns": [
        ".github/templates/*",
        ".vscode/base.code-workspace",
        ".vscode/*.tamplate.jsonc",
        ".vscode/snippets/*.tamplate.code-snippets",
        ".codex/mcp/*.template.*"
      ],
      "forbiddenOwnershipMarkers": [
        "single source of truth",
        "global rules live here",
        "always applied"
      ]
    },
    {
      "id": "codex-skills",
      "description": "Execution-specialized Codex skills that must reference canonical repository policy.",
      "pathPatterns": [
        ".codex/skills/*/SKILL.md"
      ],
      "forbiddenOwnershipMarkers": [
        "single source of truth",
        "global rules live here"
      ]
    },
    {
      "id": "orchestration",
      "description": "Pipeline contracts, evals, and handoff artifacts.",
      "pathPatterns": [
        ".codex/orchestration/*",
        "scripts/orchestration/*"
      ]
    },
    {
      "id": "runtime-projection",
      "description": "Scripts that render the versioned source of truth into local runtime locations.",
      "pathPatterns": [
        "scripts/runtime/*"
      ]
    }
  ]
}